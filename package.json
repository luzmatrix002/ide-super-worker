{
  "name": "ide-super-worker",
  "version": "2.5.0",
  "description": "Cost-saving async MCP worker for Codex that runs Claude Code through cheap OpenAI-compatible gateways.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "setup": "tsx src/setup.ts",
    "doctor": "tsx src/doctor.ts",
    "doctor:network": "tsx src/doctor.ts --network",
    "codex:audit": "node scripts/codex_audit.mjs",
    "codex:guard": "npm run codex:audit -- --since-minutes=60 && npm run stats:gate",
    "skills:validate": "node scripts/validate_skills.mjs",
    "stats": "node scripts/stats.mjs",
    "stats:gate": "node scripts/stats.mjs --gate --since-minutes=60",
    "smoke": "npm run build && node dist/smoke_test.js",
    "test": "npm run build && node dist/tests/core.test.js && node dist/tests/routing_contract.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "PROMO.md",
    "RELEASE_CHECKLIST.md",
    "codex-mcp.example.toml",
    "docs",
    ".env.example"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/luzmatrix002/ide-super-worker.git"
  },
  "bugs": {
    "url": "https://github.com/luzmatrix002/ide-super-worker/issues"
  },
  "homepage": "https://github.com/luzmatrix002/ide-super-worker#readme",
  "author": "luzmatrix002",
  "license": "MIT"
}
