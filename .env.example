# Copy to .env and fill in. .env is gitignored; never commit real keys.

# --- Primary cheap gateway (OpenAI-compatible) ---
ONEAPI_BASE_URL=https://your-gateway.example.com/v1
ONEAPI_API_KEY=replace-me
USE_OPENAI_ADAPTER=1
ADAPTER_ENABLE_THINKING=0

# Real backend model / Claude Code local-validation model.
CLAUDE_MODEL=deepseek-v4-flash
CLAUDE_CODE_MODEL=sonnet

# Sandbox root: all allowed_dirs must resolve inside this directory.
SANDBOX_ROOT=D:/your/workspaces

# --- Fallback gateway (used automatically when primary is unreachable/erroring) ---
FALLBACK_BASE_URL=https://api.deepseek.com
FALLBACK_API_KEY=replace-me
FALLBACK_MODEL=deepseek-v4-flash
FALLBACK_ESCALATE_MODEL=deepseek-v4-pro

# --- Optimizations (optional) ---
# Auto-escalate model on a hard revise pass (O6).
WORKER_ESCALATE_MODEL=deepseek-v4-pro
WORKER_ESCALATE_DIFFICULTY=0.6
# Usage/cost JSONL for observability (O7). Real cost = these tokens x provider price.
WORKER_METRICS_FILE=D:/your/workspaces/.worker-metrics.jsonl
# WORKER_METRICS_SHARD_BY_PID=1
# O19: optional stats price inputs, in USD per 1M tokens.
# WORKER_PRICE_INPUT=0.27
# WORKER_PRICE_OUTPUT=1.10
# WORKER_PRICE_CACHE=0.027
# WORKER_PRICE_TABLE={"deepseek-v4-pro":{"input":0.55,"output":2.19}}
# O20: cheap model and optional disk cache for analyze/review/failure_digest.
# WORKER_LITE_MODEL=deepseek-v4-flash
# WORKER_LITE_CACHE_DIR=D:/your/workspaces/.worker-lite-cache
# WORKER_LITE_CACHE_TTL_MS=3600000
# O21: prefix-cache-friendly analyze request structure.
# ADAPTER_PREFIX_CACHE=0
# O23: warn every N fallback calls; 0 disables the warning.
# WORKER_FALLBACK_WARN_EVERY=5
# O10/O11: compact default responses and optionally omit diffs when callers forget include_diff.
CHECK_OUTPUT_RESPONSE_MAX=2000
INCLUDE_DIFF_DEFAULT=1
# O14/O15: summarize failed jobs cheaply and allow one extra gateway-side revise pass.
# WORKER_FAILURE_DIGEST=1
# WORKER_DIGEST_BEFORE_REVISE=1
MYTHOS_MAX_REVISE_PASSES=2
# git worktree isolation for safe single-repo parallelism (O8).
# WORKER_ISOLATION=worktree
# WORKER_WORKTREE_DIR=D:/your/workspaces/.worker-worktrees

# --- Optional tuning ---
CLAUDE_PERMISSION_MODE=acceptEdits
DIFF_MAX_BYTES=200000
WAIT_DEFAULT_MS=1800000
