# Copy to .env and fill in. .env is gitignored; never commit real keys.

# --- Primary cheap gateway (OpenAI-compatible) ---
ONEAPI_BASE_URL=https://your-gateway.example.com/v1
ONEAPI_API_KEY=replace-me
USE_OPENAI_ADAPTER=1
ADAPTER_ENABLE_THINKING=0

# Real backend model / Claude Code local-validation model.
CLAUDE_MODEL=deepseek-v4-flash
CLAUDE_CODE_MODEL=sonnet

# Sandbox root: all allowed_dirs must resolve inside this directory.
SANDBOX_ROOT=D:/your/workspaces

# --- Fallback gateway (used automatically when primary is unreachable/erroring) ---
FALLBACK_BASE_URL=https://api.deepseek.com
FALLBACK_API_KEY=replace-me
FALLBACK_MODEL=deepseek-v4-flash
FALLBACK_ESCALATE_MODEL=deepseek-v4-pro
# Worker LLM routing is not cost-capped. Primary, fallback, and escalation
# models are selected by capability/reliability config, not by price.

# --- Optimizations (optional) ---
# Auto-escalate model on a hard revise pass (O6).
WORKER_ESCALATE_MODEL=deepseek-v4-pro
WORKER_ESCALATE_DIFFICULTY=0.6
# Usage/cost JSONL for observability (O7). Real cost = these tokens x provider price.
WORKER_METRICS_FILE=D:/your/workspaces/.worker-metrics.jsonl
# Separate hook-observable opportunity log; never mix with WORKER_METRICS_FILE.
WORKER_ROUTING_EVENTS_FILE=D:/your/workspaces/.worker-routing-observations.jsonl
# Atomic Windows watchdog state file.
WORKER_GUARD_STATUS_FILE=D:/your/workspaces/.worker-guard-status.json
# Optional local HMAC keys. Without them, fingerprints are correlation-only hashes.
WORKER_ROUTING_HASH_KEY=
WORKER_COMMAND_FINGERPRINT_KEY=
# Quality-first analyze/review. Keep this JSON outside the repo; it references
# API-key environment variable names and never embeds key values.
# WORKER_QUALITY_TARGETS_FILE=D:/secure/worker-quality-targets.json
# QUALITY_KEY_A=replace-me
# QUALITY_KEY_B=replace-me
# QUALITY_KEY_C=replace-me
# QUALITY_REVIEW_KEY=replace-me
# WORKER_FANOUT_ENABLED=1
# WORKER_FANOUT_MAX_BRANCHES=3
# WORKER_FANOUT_MAX_ACTIVE=1
# WORKER_LITE_MAX_CONCURRENCY=3
# WORKER_GLOBAL_LITE_MAX=3
# WORKER_GLOBAL_LITE_QUEUE_MAX=6
# WORKER_GLOBAL_ACQUIRE_TIMEOUT_MS=15000
# WORKER_FANOUT_TIMEOUT_MS=270000
# Dedicated, cache-free semantic verifier used only when semantic_gate is warn/required.
# WORKER_SEMANTIC_REVIEW_MODEL=deepseek-v4-pro
# WORKER_SEMANTIC_REVIEW_TIMEOUT_MS=60000
# Separate paired-evaluation output. Never point this at WORKER_METRICS_FILE.
# WORKER_EVAL_SPAN_FILE=D:/your/workspaces/.eval/eval-spans.jsonl
# WORKER_EVAL_SUITE_ID=pilot-v1
# WORKER_EVAL_TASK_ID=search-read-01
# WORKER_EVAL_RUN_ID=run-001
# WORKER_EVAL_ARM=worker
# O10/O11: compact default responses and optionally omit diffs when callers forget include_diff.
CHECK_OUTPUT_RESPONSE_MAX=2000
INCLUDE_DIFF_DEFAULT=1
# O14/O15: summarize failed jobs cheaply and allow one extra gateway-side revise pass.
# WORKER_FAILURE_DIGEST=1
# WORKER_DIGEST_BEFORE_REVISE=1
MYTHOS_MAX_REVISE_PASSES=2
# git worktree isolation for safe single-repo parallelism (O8).
# WORKER_ISOLATION=worktree
# WORKER_WORKTREE_DIR=D:/your/workspaces/.worker-worktrees
# Exit an idle MCP server after 5 minutes; set 0 for clients that require a persistent connection.
# WORKER_IDLE_EXIT_MS=300000

# Advanced stats, cache, reliability, and circuit-breaker options:
# see docs/advanced-config.md.

# --- Optional tuning ---
CLAUDE_PERMISSION_MODE=acceptEdits
DIFF_MAX_BYTES=200000
WAIT_DEFAULT_MS=1800000
